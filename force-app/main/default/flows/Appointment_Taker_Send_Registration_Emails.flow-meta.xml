        <label>Loop OLIs</label>
        <locationX>314</locationX>
        <locationY>539</locationY>
        <collectionReference>Get_Appointment_Taker_OLIs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_Increment_Total</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
