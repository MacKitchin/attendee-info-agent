    <description
  >Sends follow-up registration emails when Opportunity moves to Closed Won with supported attendee-registration products and attendee details are still missing. Creates outbound processing logs and records email send failures.</description>
    <environments>Default</environments>
    <formulas>
        <name>Formula_Registration_Type</name>
        <dataType>String</dataType>
        <expression
    >IF({!Loop_OLIs.Product2Id} = &quot;01t4X000004U14AQAS&quot;, &quot;Non-Appointment Taker&quot;, 
IF({!Loop_OLIs.Product2Id} = &quot;01t4X000004U148QAC&quot;, &quot;Marketer&quot;, &quot;Appointment Taker&quot;))</expression>
    </formulas>
    <interviewLabel
  >Appointment Taker - Send Registration Emails {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Appointment Taker - Send Registration Emails</label>
    <loops>
