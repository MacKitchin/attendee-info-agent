<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>This daily flow will check all active Account Status accounts to confirm they should remain as active based on when their last closed/won opportunity was.</description>
    <environments>Default</environments>
    <formulas>
        <name>ThreeYearsAgoFromToday</name>
        <dataType>Date</dataType>
        <expression>DATE(year(today()) - 3,month(today()),day(today()))</expression>
    </formulas>
    <interviewLabel>Automatically check accounts with Account Status as Active {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Automatically check accounts with Account Status as Active</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>If their last won opportunity was more than 3 years ago, then it can no longer be considered active.</description>
        <name>Update_Account_Status_as_Inactive_if_last_won_opportunity_was_long_ago</name>
        <label>Update Account Status as Inactive if last won opportunity was long ago</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Last_Won_Opportunity_Date__c</field>
            <operator>LessThan</operator>
            <value>
                <elementReference>ThreeYearsAgoFromToday</elementReference>
            </value>
        </filters>
        <filters>
            <field>Last_Won_Opportunity_Date__c</field>
            <operator>EqualTo</operator>
        </filters>
        <inputAssignments>
            <field>Account_Status__c</field>
            <value>
                <stringValue>Inactive</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Account_Status_as_Inactive_if_last_won_opportunity_was_long_ago</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Account_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Active</stringValue>
            </value>
        </filters>
        <object>Account</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2024-10-09</startDate>
            <startTime>02:15:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
