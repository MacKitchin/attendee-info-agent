    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Check_the_Primary_Category_and_Account_Status_value</name>
        <label>Check the Primary Category and Account Status value</label>
        <locationX>314</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Has_Primary_Category_meant_for_Connect_but_Account_Status_is_NOT_For_Connect</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Primary_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Supplier-Destination/CVB</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>For Connect</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Status_as_For_Connect</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Has Primary Category meant for Connect but Account Status is NOT For Connect</label>
        </rules>
        <rules>
            <name>Has_Non_Connect_value_for_Primary_Category_but_Account_Status_is_For_Connect</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Primary_Category__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Supplier-Destination/CVB</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>For Connect</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Status_as_NULL</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Has Non-Connect value for Primary Category but Account Status is For Connect</label>
        </rules>
    </decisions>
    <description>Updated to remove the Venue categories for Connect as BizBash will now advertise to those categories.</description>
