/**
 * CreateFollowUpTask
 *
 * Invocable Apex that creates a Salesforce Task on an Opportunity for
 * reviewing attendee assignment failures. The Task is assigned to
 * mac.kitchin@informa.com when that user exists, otherwise falls back
 * to the running user.
 *
 * Called from Flow as step 3 of the failure-task feature, after the AI
 * summary has been generated by BuildFailureContext + prompt.
 */
public with sharing class CreateFollowUpTask {
  // ─── INPUT WRAPPER ───
  public class FollowUpTaskInput {
    @InvocableVariable(
      label='Opportunity ID'
      required=true
      description='The Opportunity to attach the Task to (Task.WhatId)'
    )
    public Id opportunityId;

    @InvocableVariable(
      label='AI Summary'
      description='AI-generated narrative for Task.Description'
    )
    public String aiSummary;

    @InvocableVariable(
      label='Opportunity Name'
      required=true
      description='Used in the Task Subject, truncated to 200 chars'
    )
    public String opportunityName;

    @InvocableVariable(
      label='Status Message'
      description='Fallback for Task.Description if aiSummary is blank'
    )
    public String statusMessage;
  }

  // ─── OUTPUT WRAPPER ───
  public class FollowUpTaskOutput {
    @InvocableVariable(label='Success')
    public Boolean success;

    @InvocableVariable(label='Task ID')
    public Id taskId;

    @InvocableVariable(label='Error Message')
    public String errorMessage;
  }

  @InvocableMethod(
    label='Create Follow-Up Task'
    description='Creates a Task on the Opportunity for reviewing attendee assignment failures, assigned to mac.kitchin@informa.com or the running user as fallback.'
    category='Attendee Processing'
  )
  public static List<FollowUpTaskOutput> createFollowUpTask(
    List<FollowUpTaskInput> inputs
  ) {
    List<FollowUpTaskOutput> outputs = new List<FollowUpTaskOutput>();

    // Resolve owner once for all inputs
    Id ownerId = resolveOwner();

    for (FollowUpTaskInput input : inputs) {
      FollowUpTaskOutput output = new FollowUpTaskOutput();
      try {
        // Build description
        String description;
        if (String.isNotBlank(input.aiSummary)) {
          description = input.aiSummary;
        } else {
          description =
            'Attendee assignment completed with status: ' +
            input.statusMessage +
            '. AI summary was unavailable.';
        }

        // Build subject with truncated opportunity name
        String subject =
          'Review Attendee Assignment Failures \u2014 ' +
          input.opportunityName.left(200);

        // Create Task
        Task followUpTask = new Task(
          Subject = subject,
          WhatId = input.opportunityId,
          OwnerId = ownerId,
          ActivityDate = Date.today().addDays(30),
          Status = 'Not Started',
          Priority = 'Normal',
          Description = description,
          Type = 'Other'
        );
        insert as system followUpTask;

        output.success = true;
        output.taskId = followUpTask.Id;
      } catch (Exception e) {
        output.success = false;
        output.errorMessage = e.getMessage();
      }
      outputs.add(output);
    }
    return outputs;
  }

  /**
   * @description Resolves the Task owner by looking up mac.kitchin@informa.com.
   *              Falls back to the running user if not found.
   */
  private static Id resolveOwner() {
    List<User> users = [
      SELECT Id
      FROM User
      WHERE Email = 'mac.kitchin@informa.com' AND IsActive = TRUE
      WITH SYSTEM_MODE
      LIMIT 1
    ];

    if (!users.isEmpty()) {
      return users[0].Id;
    }

    System.debug(
      LoggingLevel.WARN,
      'CreateFollowUpTask: mac.kitchin@informa.com not found or inactive. Falling back to running user.'
    );
    return UserInfo.getUserId();
  }
}
